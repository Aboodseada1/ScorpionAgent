# Go backend (new)
PORT=8001
ADMIN_TOKEN=

# Local OpenAI-compatible LLM (llama.cpp llama-server)
LLM_BASE_URL=http://127.0.0.1:8080/v1
LLM_MODEL=local
LLM_TEMPERATURE=0.35
LLM_MAX_TOKENS=220

# Whisper.cpp HTTP server (run: whisper.cpp/server -m models/ggml-base.en.bin --port 9000)
WHISPER_BASE_URL=http://127.0.0.1:9000
WHISPER_MODEL=base.en

# Piper TTS
PIPER_BIN=/usr/local/bin/piper
PIPER_MODEL=/opt/piper/voices/en_US-lessac-medium.onnx
PIPER_CONFIG=/opt/piper/voices/en_US-lessac-medium.onnx.json

# VAD / AEC
VAD_THRESHOLD=0.55
VAD_MIN_SILENCE_MS=500
VAD_SPEECH_PAD_MS=80
TTS_ACOUSTIC_TAIL_MS=850
BARGE_IN_GUARD_MS=550
SELF_FILTER_NGRAM=6

# KB embeddings (optional)
EMBED_BASE_URL=http://127.0.0.1:8080/v1
EMBED_MODEL=local
KB_TOP_K=5
KB_MAX_CONTEXT_CHARS=2800

# Groq (optional): single key, or comma-separated rotation pool (server-side only; Settings UI shows masked suffixes).
# GROQ_API_KEY=
# GROQ_API_KEYS=key1,key2,key3,key4,key5
# GROQ_OPENAI_BASE_URL=https://api.groq.com/openai/v1

# Cascade router (optional): when LLM_PROVIDER=groq, route simple user turns to local llama.cpp and complex to Groq.
# Requires local llama-server reachable at LLM_BASE_URL. Set to 1 to enable.
# LLM_CASCADE=0
# CASCADE_LOCAL_MODEL=Qwen2.5-3B-Instruct
# CASCADE_GROQ_MODEL=llama-3.1-8b-instant

# Data
DATA_DIR=./data
MODELS_DIR=./models
PROMPTS_DIR=./prompts
